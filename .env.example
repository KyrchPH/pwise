# =====================================================================
# Auto Post Agent — shared environment (server + scripts)
# Copy to .env and fill in real values.  .env is git-ignored.
# Client (Vite) env lives in client/.env  — see client/.env.example
# =====================================================================

# --- Server ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://user:password@localhost:5432/auto_post_agent

# --- JWT ---
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET_NAME=

# --- Email (Nodemailer / Resend / SMTP) ---
EMAIL_PROVIDER=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# --- Scheduler ---
# Shared secret required in the x-scheduler-secret header on POST /api/scheduler/run
SCHEDULER_SECRET=
# Base URL the scripts worker calls when triggering the scheduler
SERVER_URL=http://localhost:5000

# --- Platform API (added in later phase) ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=
