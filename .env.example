# =====================================================================
# Auto Post Agent — shared environment (server + scripts)
# Copy to .env and fill in real values.  .env is git-ignored.
# Client (Vite) env lives in client/.env  — see client/.env.example
# =====================================================================

# --- Server ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- Database (MySQL) ---
DATABASE_URL=mysql://user:password@your-ec2-host:3306/auto_post_agent
# Set to true if your MySQL requires TLS (some managed/remote instances do)
DB_SSL=false

# --- JWT ---
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET_NAME=

# --- Email (Nodemailer / Resend / SMTP) ---
EMAIL_PROVIDER=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# --- Service auth (n8n -> server machine endpoints) ---
# n8n sends this as the `x-service-token` header to call /api/scheduler/* .
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVICE_TOKEN=
# Base URL n8n / the scripts worker call
SERVER_URL=http://localhost:5000

# --- S3 presigned URL lifetimes (seconds, optional) ---
UPLOAD_URL_TTL_SECONDS=300
DOWNLOAD_URL_TTL_SECONDS=3600

# --- Platform API ---
# NOTE: in this architecture n8n calls the Meta Graph API directly, so these
# belong in n8n's credentials, not the server. Kept here for reference only.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=
