# server/.env — the COMPLETE server config (copy to server/.env, fill in). Gitignored.
# In a FLAT PRODUCTION DEPLOY this single file is everything the server needs —
# place it next to server.js on the box. (The repo-root .env is a dev-only
# fallback for the scripts/ workspace; prod does NOT need it.)
# On boot the server logs an [env] warning for any required var that's missing.

# --- Server ---
PORT=5000
NODE_ENV=production
CLIENT_URL=https://pwise.sixpent.com   # the browser origin, for CORS

# --- Database (MySQL) ---
DATABASE_URL=mysql://user:password@host:3306/pwise
DB_SSL=false

# --- JWT ---
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- Service auth: n8n -> /api/scheduler/*  (MUST match n8n's x-service-token header) ---
SERVICE_TOKEN=

# --- AWS S3 ---
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=pwise-files
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_ACCESS_KEY=

# --- Facebook / Meta Graph API (delete/edit/comment-reads on published posts) ---
# Long-lived Page token with pages_manage_posts + pages_read_user_content.
FACEBOOK_PAGE_ACCESS_TOKEN=
FB_GRAPH_VERSION=v21.0
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_APP_CLIENT_TOKEN=
