# server/.env — server-only secrets (copy to server/.env and fill in). Gitignored.
# The server uses these to call the Meta/Facebook Graph API for user-initiated
# delete / edit / comment-reads on published posts. (Publishing stays in n8n.)
# Loaded by server.js with PRECEDENCE over the shared repo-root .env.

# --- Facebook / Meta Graph API ---
# Long-lived Page access token (needs pages_manage_posts + pages_read_user_content).
FACEBOOK_PAGE_ACCESS_TOKEN=
FB_GRAPH_VERSION=v21.0

# App credentials — used to refresh/extend the page token (not at runtime).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_APP_CLIENT_TOKEN=
