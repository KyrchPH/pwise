# server/.env — the COMPLETE server config (copy to server/.env, fill in). Gitignored.
# In a FLAT PRODUCTION DEPLOY this single file is everything the server needs —
# place it next to server.js on the box. (The repo-root .env is a dev-only
# fallback for the scripts/ workspace; prod does NOT need it.)
# On boot the server logs an [env] warning for any required var that's missing.

# --- Server ---
PORT=5000
NODE_ENV=production
CLIENT_URL=https://pwise.sixpent.com   # the browser origin, for CORS

# --- Database (MySQL) ---
DATABASE_URL=mysql://user:password@host:3306/pwise
DB_SSL=false

# --- JWT ---
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- Service auth: n8n -> /api/scheduler/*  (MUST match n8n's x-service-token header) ---
SERVICE_TOKEN=

# --- AWS S3 ---
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=pwise-files
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_ACCESS_KEY=

# --- Facebook / Meta Graph API ---
# Pages are now managed in-app (Settings → Facebook Pages, encrypted in the DB).
# These vars are only the SEED for the first page: `npm run fb:import-env` imports
# them into the pages table. FB_GRAPH_VERSION is still used as the default version.
FACEBOOK_PAGE_ACCESS_TOKEN=
FB_GRAPH_VERSION=v21.0
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_APP_CLIENT_TOKEN=

# --- Encryption (connected page credentials stored in the DB) ---
# 32-byte key as 64 hex chars: `openssl rand -hex 32`. Required to add/use pages.
# Keep it stable — rotating it makes existing encrypted credentials unreadable.
ENCRYPTION_KEY=

# --- "Generate with Template" (Upload page) ---
# Rendering is delegated to n8n: the server triggers this webhook, n8n runs the
# Creatomate render and responds with the output video URL. No Creatomate API key
# lives here (it stays in n8n). Set this to your "Post to n8n" webhook URL.
N8N_GENERATE_WEBHOOK_URL=
# Optional: if you protect that webhook, this is sent as the x-service-token header.
N8N_WEBHOOK_TOKEN=
# The template element name the input video is injected into (default matches the
# Creatomate docs + the n8n flow). Override only if your templates differ.
CREATOMATE_VIDEO_KEY=Background-Video
