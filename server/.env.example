# server/.env — the COMPLETE server config (copy to server/.env, fill in). Gitignored.
# In a FLAT PRODUCTION DEPLOY this single file is everything the server needs —
# place it next to server.js on the box. (The repo-root .env is a dev-only
# fallback for the scripts/ workspace; prod does NOT need it.)
# On boot the server logs an [env] warning for any required var that's missing.

# --- Server ---
PORT=5000
NODE_ENV=production
CLIENT_URL=https://pwise.sixpent.com   # the browser origin, for CORS
# Public HTTPS base URL of THIS API. Messaging platforms (Telegram, Messenger,
# Instagram, WhatsApp) POST inbound here, so it MUST be publicly reachable — NOT localhost.
# When you connect a Telegram bot in Settings, its webhook is registered as
# <PUBLIC_URL>/api/webhooks/telegram?accountId=…  — if PUBLIC_URL is unset, NO
# webhook is registered and the bot's messages never reach the app.
PUBLIC_URL=https://pwise-api.sixpent.com

# --- Database (MySQL) ---
DATABASE_URL=mysql://user:password@host:3306/pwise
DB_SSL=false

# --- JWT ---
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- Service auth: n8n -> /api/scheduler/*  (MUST match n8n's x-service-token header) ---
SERVICE_TOKEN=

# --- Redis (optional) -------------------------------------------------------
# Shared store for agent presence ("online now") so order routing is correct
# across multiple server instances. Leave UNSET to use in-memory presence (fine
# for a single server process). Examples:
#   Docker Redis on the same EC2 host (compose publishes 127.0.0.1:6379:6379):
#     REDIS_URL=redis://127.0.0.1:6379
#   API also in Docker — use the Redis service/container name on the shared
#   network (no published port needed): REDIS_URL=redis://redis:6379
#   With a password: REDIS_URL=redis://:YOUR_PASSWORD@127.0.0.1:6379
REDIS_URL=

# --- AWS S3 ---
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=pwise-files
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_ACCESS_KEY=

# --- Facebook / Meta Graph API ---
# Pages are now managed in-app (Settings → Facebook Pages, encrypted in the DB).
# These vars are only the SEED for the first page: `npm run fb:import-env` imports
# them into the pages table. FB_GRAPH_VERSION is still used as the default version.
# FACEBOOK_APP_SECRET also signs the X-Hub-Signature-256 on ALL Meta inbound webhooks
# (Messenger, Instagram, WhatsApp — one app, one secret).
FACEBOOK_PAGE_ACCESS_TOKEN=
FB_GRAPH_VERSION=v21.0
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_APP_CLIENT_TOKEN=

# --- Encryption (connected page credentials stored in the DB) ---
# 32-byte key as 64 hex chars: `openssl rand -hex 32`. Required to add/use pages.
# Keep it stable — rotating it makes existing encrypted credentials unreadable.
ENCRYPTION_KEY=

# --- "Generate with Template" (Upload page) ---
# Rendering is delegated to n8n: the server triggers this webhook, n8n runs the
# Creatomate render and responds with the output video URL. No Creatomate API key
# lives here (it stays in n8n). Set this to your "Post to n8n" webhook URL.
N8N_GENERATE_WEBHOOK_URL=
# "Post now" pushes immediate posts to the same "Post to n8n" webhook (the flow's
# IF routes on for_automation). Optional override if you split it into its own
# webhook; defaults to N8N_GENERATE_WEBHOOK_URL.
N8N_POST_WEBHOOK_URL=
# Optional: if you protect that webhook, this is sent as the x-service-token header.
N8N_WEBHOOK_TOKEN=
# Dev Wise Assistant overlay -> server -> n8n chat workflow. The overlay calls
# /api/wise-assistant/ask, and the server forwards the request here.
N8N_WISE_ASSISTANT_WEBHOOK_URL=
# Optional shared secret header the server sends as x-wise-assistant-secret.
N8N_WISE_ASSISTANT_SECRET=
# The template element names that "Generate with Template" injects into — the input
# video, the optional in-video image, and the optional in-video text. They MUST match
# the element names in your Creatomate template; override if your templates differ.
CREATOMATE_VIDEO_KEY=Background-Video
CREATOMATE_TEXT_KEY=Text-1
CREATOMATE_IMAGE_KEY=Image-1

# --- Inbound messaging gateway (Telegram/Messenger/Instagram/WhatsApp → server → n8n AI) ---
# Customer messages hit /api/webhooks/{telegram,messenger,instagram,whatsapp}; the gateway
# records them in the inbox and, WHILE a thread is AI-handled, forwards them to n8n for an
# AI reply. Requires PUBLIC_URL (top of this file) so the bot webhook can be registered.
#
# Production webhook URL of your n8n inbound workflow's HTTP Webhook node (e.g. path
# "ai-inbound"). It MUST be the ACTIVE /webhook/ URL — NOT the /webhook-test/ URL,
# which only fires once while the n8n canvas is open. If unset, inbound messages are
# recorded in the inbox but never forwarded to n8n (the AI never replies).
N8N_AI_WEBHOOK_URL=
# Optional shared secret the gateway sends as the x-gateway-secret header.
N8N_AI_SECRET=
# Optional but recommended. A random string handed to Telegram at setWebhook time;
# Telegram echoes it back in X-Telegram-Bot-Api-Secret-Token and the server rejects
# any inbound call that doesn't match. If you change it, reconnect the bot in
# Settings so Telegram is re-registered with the new value.
TELEGRAM_WEBHOOK_SECRET=
# Meta webhook GET-handshake verify token, configured in the Meta App dashboard. SHARED
# by Messenger, Instagram, and WhatsApp (one app) — set each product's callback URL to
# <PUBLIC_URL>/api/webhooks/{messenger,instagram,whatsapp} with THIS verify token. Also
# gates whether the server auto-subscribes pages to Messenger. Instagram replies reuse the
# page access token; each WhatsApp number's own token is stored per-page (encrypted, in
# Settings → Facebook Pages → WhatsApp), not here.
FB_WEBHOOK_VERIFY_TOKEN=
# Feature flag (runtime): when true, a live agent can hand a conversation back to the
# AI agent from the inbox (double-click the customer's avatar in a Live Agent thread).
# Off by default — turn on for controlled testing in production.
ALLOW_TRANSFER_TO_AI=false

# --- AI Agent vector store (Supabase Postgres + OpenAI embeddings) ---
# Used by the scripts/ workspace: `npm run vectors:sync` mirrors the MySQL
# `products` and `ai_agent_reference` tables into the Supabase pgvector table
# `public.agent_documents`, which the n8n "Supabase Vector Store" node reads.
# The sync reads the MySQL source via DATABASE_URL (above) and writes to Supabase
# via the connection below. (The scripts also read repo-root .env, so these may
# live there alongside DATABASE_URL instead.) See scripts/agent-vectors.README.md.
OPENAI_API_KEY=
# Also used by the SERVER for the messaging composer's "Enhance" button (a direct
# OpenAI chat call, separate from the vector sync). Unset -> Enhance returns 503.
# Chat model for Enhance (override if your key can't call this one):
OPENAI_ENHANCE_MODEL=gpt-5.4-mini
# Optional. Defaults to text-embedding-3-small (1536-dim). If you change it you
# must also update vector(1536) in scripts/database/supabase/agent_vectors.sql,
# re-run the sync, AND use the SAME model in n8n at query time.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Supabase Postgres target (the vector DB). Prefer the full connection string and
# use the connection-pooler host. If it still contains [YOUR-PASSWORD], that is
# filled from SUPABASE_DB_PASSWORD.
SUPABASE_CONNECTION_STRING=
SUPABASE_DB_PASSWORD=

# --- Geoapify (optional) ----------------------------------------------------
# Geocoding + driving distance for the AI agent's delivery-distance check (the
# check_delivery_distance tool: is the customer's delivery address near the shop, or
# far enough to steer them to the online store?). Free tier is plenty for order-time
# use. Get a key at https://myprojects.geoapify.com. Unset -> the tool returns
# available:false and the agent falls back to judging near/far from the address text.
GEOAPIFY_API_KEY=
