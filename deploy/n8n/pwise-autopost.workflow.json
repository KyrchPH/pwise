      "typeVersion": 4.2,
      "position": [
        220,
        40
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v21.0/{{ $('Keystore').item.json.PAGE_ID }}/photos",
        "sendBody": true,
