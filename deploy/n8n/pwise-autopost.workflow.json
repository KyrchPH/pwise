    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "ks-page-id",
              "name": "PAGE_ID",
              "value": "YOUR_PAGE_ID",
              "type": "string"
            },
            {
              "id": "ks-page-token",
              "name": "PAGE_ACCESS_TOKEN",
              "value": "YOUR_PAGE_ACCESS_TOKEN",
              "type": "string"
            },
            {
              "id": "ks-admin-email",
              "name": "ADMIN_EMAIL",
              "value": "owner@example.com",
              "type": "string"
