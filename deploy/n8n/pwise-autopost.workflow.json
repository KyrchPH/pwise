            {
              "name": "caption",
              "value": "={{ $('Claim next post').item.json.data.post.caption }}"
            },
            {
              "name": "access_token",
              "value": "={{ $('Keystore').item.json.PAGE_ACCESS_TOKEN }}"
            }
