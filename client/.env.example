# Client (Vite) environment. Copy to client/.env
# Only VITE_-prefixed vars are exposed to the browser.

# Base URL for API calls. In dev, leave as "/api" to use the Vite proxy
# (see vite.config.js) which forwards to the Express server.
VITE_API_BASE_URL=/api

# Show the Creatomate "Use template" feature (still unfinished). The Vite dev
# server shows it automatically; set this true in a testing build to expose it
# there too. Leave false/unset in production.
VITE_ENABLE_TEMPLATES=true
