# Client (Vite) environment. Copy to client/.env
# Only VITE_-prefixed vars are exposed to the browser.

# Base URL for API calls. In dev, leave as "/api" to use the Vite proxy
# (see vite.config.js) which forwards to the Express server.
VITE_API_BASE_URL=/api

# The Creatomate "Generate with Template" feature (input video + in-video text/image).
# Enabled by default everywhere, including production. Set to false to hide it.
VITE_ENABLE_TEMPLATES=true

# Show the Wise Assistant ("Rovi") help overlay. The Vite dev server shows it
# automatically; set this true in any other build (e.g. production) to show it there.
VITE_SHOW_ASSISTANT=true
